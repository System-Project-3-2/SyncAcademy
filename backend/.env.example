PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/lms
REDIS_URL=redis://localhost:6379

JWT_SECRET=replace_me

LOG_LEVEL=info
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

MONGO_MAX_POOL_SIZE=200
MONGO_MIN_POOL_SIZE=50
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=45000

ENABLE_API_CACHE=true
API_CACHE_TTL_SECONDS=300
SEARCH_CACHE_TTL_SECONDS=300

RATE_LIMIT_USE_REDIS=true
RATE_LIMIT_MAX_PER_MINUTE=20000
AUTH_RATE_LIMIT_MAX=500
THROTTLE_AFTER=1000
THROTTLE_DELAY_MS=50

ENABLE_ASYNC_QUIZ_GENERATION=true
ENABLE_ASYNC_MATERIAL_PROCESSING=true
ENABLE_ASYNC_NOTIFICATION_FANOUT=true

WORKER_CONCURRENCY=20

RAG_TIMEOUT_MS=20000
RAG_RETRIES=1
LLM_CIRCUIT_FAILURE_THRESHOLD=5
LLM_CIRCUIT_COOLDOWN_MS=30000

IDEMPOTENCY_TTL_SECONDS=900
